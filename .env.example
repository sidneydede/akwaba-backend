# ─── Backend Akwaba — variables d'environnement ──────────────────────────────
# Copier en `.env` (gitignore) pour le dev local. En prod, ces valeurs sont
# définies dans le dashboard Render (cf. render.yaml, clés `sync: false`).

# ─── Cœur (requis) ───────────────────────────────────────────────────────────
# URL PostgreSQL (Render la fournit automatiquement via fromDatabase)
DATABASE_URL=postgresql://user:password@host:5432/akwaba_db
# Port du serveur (Render fournit automatiquement PORT)
PORT=3000
# Secret de signature des tokens HMAC (auth mobile + admin). À générer aléatoire.
TOKEN_SECRET=change-me-in-production
NODE_ENV=development

# ─── OTP SMS — Africa's Talking (requis pour login/register) ─────────────────
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=

# ─── Paiements — CinetPay (requis pour la billetterie) ───────────────────────
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
# URL de retour affichée après paiement (défaut: /payment-success du backend)
FRONT_RETURN_URL=
# Transferts/payouts CinetPay (optionnel — désactivé si non défini)
CINETPAY_TRANSFER_ENABLED=
CINETPAY_TRANSFER_LOGIN=
CINETPAY_TRANSFER_PASSWORD=

# ─── Upload images — Cloudinary (requis pour events/avatars/bannières) ───────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Optionnels (dégradation gracieuse si absents) ───────────────────────────
# Secret HMAC des QR billets. Si vide, fallback sur TOKEN_SECRET.
QR_HMAC_SECRET=
# Crash reporting Sentry (vide = désactivé)
SENTRY_DSN=
# Email du digest admin quotidien via Resend (vide = digest stocké sans email)
RESEND_API_KEY=
RESEND_FROM=
# Force le mode paiement simulé en dev (true = pas d'appel CinetPay réel)
MOCK_PAYMENTS=

# ─── Flags de désactivation des workers en arrière-plan (dev) ────────────────
# Mettre à "true" pour couper le worker correspondant.
DISABLE_RECONCILE=
DISABLE_PAYOUT_SCHEDULING=
DISABLE_EVENT_REMINDERS=
DISABLE_ADMIN_DIGEST=
DISABLE_DATA_RETENTION=
